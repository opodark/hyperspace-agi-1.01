# =============================================================
# HyperSpace AGI v1.01 — .env per UBUNTU (Ollama nativo)
# Su Linux, host.docker.internal è iniettato dal compose
# tramite extra_hosts: host.docker.internal:host-gateway
# NON usare 172.17.0.1 — cambia ad ogni reboot
# =============================================================

# Ollama nativo sul host — stabile su qualsiasi Linux con Docker Engine
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:latest

# Identità nodo
NODE_HOSTNAME=node-ubuntu
NODE_PORT=8084

# Endpoint pubblico di questo nodo (ngrok statico Ubuntu)
PUBLIC_ENDPOINT=https://sanctuary-mower-plated.ngrok-free.dev

# Boot peers: Mac è il primo seed
BOOT_PEERS=https://charlesetta-haptical-unconcentratedly.ngrok-free.dev

# Registry locale Ubuntu
REGISTRY_PORT=8086
NODE_TTL=120

# Control plane sul Mac via Tailscale
CONTROL_PLANE_URL=http://100.81.234.102:8085

# Heartbeat
HEARTBEAT_INTERVAL=20

# Open WebUI
WEBUI_SECRET_KEY=hyperspace-secret-change-me

# Inference backend
INFERENCE_BACKEND=ollama
