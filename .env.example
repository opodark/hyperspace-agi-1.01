# HyperSpace AGI v0.2 — Environment Config
# Copia in .env e personalizza per ogni macchina.

# Hostname o IP pubblico di questo nodo (usato per registrarsi ai peer)
NODE_HOSTNAME=localhost

# Peers iniziali — IP:porta degli altri nodi nella rete, separati da virgola
# Es: BOOT_PEERS=192.168.1.11:8084,192.168.1.12:8084
BOOT_PEERS=

# Lista nodi da monitorare nel control-plane (host:porta, separati da virgola)
# Es: NODE_ENDPOINTS=node:8084,192.168.1.11:8084
NODE_ENDPOINTS=node:8084

# Ollama
# macOS/Linux host Ollama: OLLAMA_URL=http://host.docker.internal:11434
# Docker Ollama:           OLLAMA_URL=http://ollama:11434
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=phi3

# Dashboard secret (opzionale)
WEBUI_SECRET_KEY=hyperspace-secret-change-me
