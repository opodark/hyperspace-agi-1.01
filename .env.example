# =============================================================
# HyperSpace AGI v0.2 — Configurazione
# Copia in .env e personalizza
# =============================================================

# --- Ollama / LLM backend ---
# URL raggiungibile DAI CONTAINER Docker
# macOS:  http://host.docker.internal:11434
# Linux:  http://172.17.0.1:11434
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3

# --- Nodo locale ---
NODE_HOSTNAME=node
NODE_PORT=8084
NODE_TIER=leaf
VRAM_GB=0.0

# --- Endpoint pubblico di questo nodo ---
# URL con cui altri nodi (anche remoti) raggiungono questo nodo.
# Mac con ngrok seed: PUBLIC_ENDPOINT=https://charlesetta-haptical-unconcentratedly.ngrok-free.dev
# Ubuntu (nodo remoto senza ngrok): lascia vuoto se non ha un URL pubblico
#   in questo caso il Mac lo raggiungerà tramite l'IP che l'Ubuntu registra al control-plane
PUBLIC_ENDPOINT=

# --- Seed / Boot peers ---
# Peer iniziali per entrare nella mesh (P2P, opzionale se usi CONTROL_PLANE_URL)
# Ubuntu: BOOT_PEERS=https://charlesetta-haptical-unconcentratedly.ngrok-free.dev
BOOT_PEERS=

# --- Control Plane URL ---
# URL del control-plane a cui il nodo si auto-registra al boot.
# Nodo locale (Mac, stesso Docker): http://control-plane:8085
# Nodo remoto (Ubuntu): http://host.docker.internal:8085
#   se il control-plane è esposto via ngrok:
#   CONTROL_PLANE_URL=https://charlesetta-haptical-unconcentratedly.ngrok-free.dev/cp
# ATTENZIONE: /cp richiede un secondo tunnel ngrok o path prefix sul control-plane.
# Il modo più semplice: esponi anche la porta 8085 via ngrok con un dominio separato.
CONTROL_PLANE_URL=http://control-plane:8085

# --- Control Plane: nodi noti ---
# Aggiornato automaticamente via /mesh/announce, ma puoi pre-popolare
NODE_ENDPOINTS=node:8084

# --- Open WebUI ---
WEBUI_SECRET_KEY=hyperspace-secret-change-me

# --- Inference backend (usato da setup.sh) ---
INFERENCE_BACKEND=ollama
