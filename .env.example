# =============================================================
# HyperSpace AGI v0.2 — Configurazione
# Copia in .env e personalizza
# =============================================================

# --- Ollama / LLM backend ---
# URL raggiungibile DAI CONTAINER Docker
# macOS:  http://host.docker.internal:11434
# Linux:  http://172.17.0.1:11434  (o l'IP del bridge docker0)
# LM Studio: stessa logica, porta default 1234
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3

# --- Nodo locale ---
NODE_HOSTNAME=node
NODE_PORT=8084
NODE_TIER=leaf
VRAM_GB=0.0

# --- Endpoint pubblico di questo nodo (opzionale) ---
# Se il nodo è esposto tramite ngrok, metti qui l'URL ngrok.
# Questo è l'indirizzo che il nodo pubblicizza agli altri peer.
# Esempio: PUBLIC_ENDPOINT=https://charlesetta-haptical-unconcentratedly.ngrok-free.dev
# Se vuoto, usa NODE_HOSTNAME:NODE_PORT (valido solo in rete Docker locale)
PUBLIC_ENDPOINT=

# --- Seed / Boot peers ---
# Peer con cui contattarsi al boot per entrare nella mesh.
# Supporta sia 'host:porta' che URL completi https://
# Esempio con ngrok seed:
# BOOT_PEERS=https://charlesetta-haptical-unconcentratedly.ngrok-free.dev
# Esempio con IP LAN:
# BOOT_PEERS=192.168.1.10:8084
# Più peer separati da virgola:
# BOOT_PEERS=https://xxxx.ngrok-free.dev,192.168.1.10:8084
BOOT_PEERS=

# --- Control Plane ---
# Nodi noti al control-plane (nome Docker o URL completo)
# Formato: node:8084,https://xxxx.ngrok-free.dev
NODE_ENDPOINTS=node:8084

# --- Open WebUI ---
WEBUI_SECRET_KEY=hyperspace-secret-change-me

# --- Inference backend (usato da setup.sh) ---
# ollama | lmstudio | ollama-docker
INFERENCE_BACKEND=ollama
